{
  "ros.distro": "humble",
  "terminal.integrated.defaultProfile.linux": "bash",
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
  "editor.formatOnSave": true,
  "files.associations": {
    "*.xacro": "xml",
    "*.urdf": "xml",
    "*.sdf": "xml",
    "*.launch.py": "python"
  },
  "files.exclude": {
    "build": true,
    "install": true,
    "log": true
  },
  "search.exclude": {
    "build": true,
    "install": true,
    "log": true,
    "legacy": true
  }
}
