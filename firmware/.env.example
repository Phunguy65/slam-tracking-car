# ═══════════════════════════════════════════════════════════════════════════════
# SLAM Tracking Car — Firmware Environment Configuration
#
# Copy this file to .env (or .env.home, .env.lab, etc.):
#   cp .env.example .env
#
# Then uncomment and edit values below.
#
# Usage:
#   pio run -e esp32_main           # Uses .env (default)
#   pio run -e esp32_main_home      # Uses .env.home
#   pio run -e esp32_main_lab       # Uses .env.lab
#   pio run -e esp32_cam_home       # Uses .env.home (camera board)
# ═══════════════════════════════════════════════════════════════════════════════

# ── WiFi (REQUIRED) ─────────────────────────────────────────────────────────────
# WIFI_SSID=MyHomeNetwork
# WIFI_PASSWORD=SuperSecretPassword123

# ── micro-ROS Agent (REQUIRED) ──────────────────────────────────────────────────
# AGENT_IP = IP of the host running `micro_ros_agent` (the ROS2 workstation).
# Must be reachable from the ESP32 on the same WiFi subnet.
# AGENT_IP=192.168.1.100
# AGENT_PORT=8888

# ── ESP32-CAM Network (read by ROS2 launch on host) ─────────────────────────────
# CAM_IP = IP assigned to the ESP32-CAM on the WiFi network.
# Consumed by src/slam_car_bringup/launch/robot.launch.py to build cam_url.
# Override at runtime:  ros2 launch ... cam_url:=http://<ip>:<port>/stream
# CAM_IP=192.168.1.200

# ── Motor Pins - TB6612FNG (REQUIRED) ───────────────────────────────────────────
# Left motor
# MOTOR_LEFT_PWMA=25
# MOTOR_LEFT_AIN1=26
# MOTOR_LEFT_AIN2=27
# Right motor
# MOTOR_RIGHT_PWMB=14
# MOTOR_RIGHT_BIN1=23
# MOTOR_RIGHT_BIN2=13

# ── Encoder Pins (REQUIRED) ─────────────────────────────────────────────────────
# ENCODER_LEFT_PIN=32
# ENCODER_RIGHT_PIN=33
# ENCODER_PPR=20

# ── IMU - MPU6050 I2C (REQUIRED) ────────────────────────────────────────────────
# IMU_SDA_PIN=21
# IMU_SCL_PIN=22
# IMU_ADDR=0x68

# ── Servo Pan-Tilt (REQUIRED) ───────────────────────────────────────────────────
# SERVO_PAN_PIN=18
# SERVO_TILT_PIN=19

# ── LiDAR - LDS02RR UART (REQUIRED) ─────────────────────────────────────────────
# LIDAR_RX_PIN=16
# LIDAR_TX_PIN=17
# LIDAR_MOTOR_PIN=4

# ── Status LED (REQUIRED) ───────────────────────────────────────────────────────
# LED_STATUS_PIN=2

# ── ESP32-CAM Only (REQUIRED for esp32_cam* environments) ──────────────────────
# CAM_STREAM_PORT=80
# CAM_FRAME_SIZE=FRAMESIZE_QVGA
# CAM_JPEG_QUALITY=12
