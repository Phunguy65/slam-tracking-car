# Normalized 2D bounding box (all values 0.0-1.0 relative to image dimensions)
float32 center_x   # Horizontal center position (0.0=left, 1.0=right)
float32 center_y   # Vertical center position (0.0=top, 1.0=bottom)
float32 width      # Box width as fraction of image width
float32 height     # Box height as fraction of image height
