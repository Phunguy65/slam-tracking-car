# ── IDE / Editor ─────────────────────────────────────────────────────────────
.ace-tool/
.cache/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~

# ── ROS2 build artifacts (colcon output in repo root) ────────────────────────
build/
install/
log/
*.pyc
__pycache__/
*.egg-info/

# ── PlatformIO ──────────────────────────────────────────────────────────────
firmware/.pio/
firmware/.vscode/

# ── Maps (large binary files — track selectively) ───────────────────────────
# Uncomment below to ignore all maps by default:
map_*.pgm
map_*.yaml

# ── Environment / Secrets ───────────────────────────────────────────────────
.env
*.env
*.env.*
!.env.example
!firmware/.env.example
credentials.json

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Lefthook ────────────────────────────────────────────────────────────────
.lefthook-local.yml
.gitnexus

# others
docs/report/
docs/spec/

*.pt
