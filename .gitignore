*.env
credentials.json
firmware/include/config.h
!firmware/include/config.h.example

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
