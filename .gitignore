!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~

# ── ROS2 build artifacts (colcon output in repo root) ────────────────────────
build/
install/
log/
*.pyc
__pycache__/
*.egg-info/

